        <path
            android:fillColor="@android:color/transparent"
            android:pathData="M 74,72 L 62,72"
            android:strokeWidth="10"
            android:strokeColor="#FFFFFF"
            android:strokeLineCap="round" />

        <!-- R: pata -->
        <path
            android:fillColor="@android:color/transparent"
            android:pathData="M 74,72 L 86,82"
            android:strokeWidth="10"
            android:strokeColor="#FFFFFF"
            android:strokeLineCap="round" />
